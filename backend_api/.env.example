# Environment variables for StockMate Backend API
# Copy this file to .env and fill in your values

# API Configuration
PROJECT_NAME=StockMate API
VERSION=1.0.0
API_V1_PREFIX=/api/v1
DEBUG=True

# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/stockmate
TIMESCALE_ENABLED=True

# Security Configuration
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# CORS Configuration (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ML Model Configuration
ML_MODEL_PATH=../ml_service/models/tft_final.ckpt
ML_SERVICE_URL=http://localhost:8001
ML_MODE=import

# Redis Configuration (Phase 6)
# REDIS_URL=redis://localhost:6379
CACHE_PREDICTIONS_TTL=900
